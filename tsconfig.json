{
  "compilerOptions": {
    "target": "es6",
    "module": "none",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outFile": "script.js",
    "lib": ["dom", "es6"]
  },
  "include": ["script.ts"]
}
